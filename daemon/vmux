#!/usr/bin/env python3
"""vmux — control the vmux daemon from the command line.

Usage:
  vmux status                     print service + session status
  vmux spawn <path> [--name <n>]  spawn new Claude session in directory
  vmux kill <session-id>          kill a session
  vmux attach [session-id]        attach to a session (auto-detects by cwd if no ID given)
  vmux sessions                   list sessions
  vmux restart <session-id>       kill + respawn a session
  vmux restart <service>          restart an infrastructure service (whisper|kokoro|livekit|relay)
  vmux reconnect <path>           attempt to reconnect to a session's tmux pane by re-entering standby
  vmux interrupt <session-id>     send Ctrl-C to a session
  vmux hard-interrupt <session-id>  Ctrl-C + MCP reconnect + re-enter standby
  vmux send <session-id> <text>   send a text message to a session (like web UI chat)
  vmux send-keys <session-id> <text>  send literal keystrokes to a session's terminal
  vmux send-key <session-id> <key>    send a special key (Enter, C-c, Tab, etc)
  vmux auth-code                  generate a one-time pairing code for the web app
  vmux update-if-newer            update daemon from plugin cache if newer version available
  vmux install-overlay            install overlay deps, config, startup item, and start
  vmux uninstall-overlay           stop overlay, remove startup item and optionally config
  vmux shutdown                   stop daemon and all children
"""

import json
import os
import shutil
import socket
import subprocess
import sys

SOCKET_PATH = "/tmp/vmuxd.sock"
SERVICES = {"whisper", "kokoro", "livekit", "relay"}


def _send(cmd: dict, timeout: int = 30) -> dict:
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.settimeout(timeout)
        sock.connect(SOCKET_PATH)
        sock.sendall(json.dumps(cmd).encode() + b"\n")
        buf = b""
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            buf += chunk
            if b"\n" in buf:
                break
        return json.loads(buf.decode().strip())
    except FileNotFoundError:
        _die("vmuxd is not running.\n  Start it with: launchctl start com.vmux.daemon\n  Or install: run scripts/install.sh")
    except ConnectionRefusedError:
        _die("vmuxd not responding.\n  Check logs: ~/.claude/voice-multiplexer/logs/daemon.log")
    except json.JSONDecodeError as e:
        _die(f"Bad response from daemon: {e}")
    finally:
        sock.close()


def _die(msg: str):
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(1)


def _ok(result: dict) -> bool:
    if not result.get("ok"):
        print(f"Error: {result.get('error', 'unknown error')}", file=sys.stderr)
        return False
    return True


def cmd_status():
    r = _send({"cmd": "status"})
    if not _ok(r):
        return
    version = r.get("version", "unknown")
    print(f"vmuxd v{version} (pid {r.get('daemon_pid', '?')})")
    print()
    print("Services:")
    for name, status in r.get("services", {}).items():
        icon = "✓" if status == "running" else "✗" if status in ("failed", "stopped") else "!" if status == "unhealthy" else "·"
        print(f"  {icon} {name:<12} {status}")
    print()
    sessions = r.get("sessions", [])
    if sessions:
        print(f"Sessions ({len(sessions)}):")
        for s in sessions:
            relay_id = s.get("relay_session_id") or "(pending)"
            cwd = s.get("cwd", "")
            status = s.get("status", "?")
            tmux = s.get("tmux_session", "")
            name = s.get("session_name", "")
            label = f"{name} " if name else ""
            print(f"  [{status}] {label}{relay_id}  {cwd}  ({tmux})")
    else:
        print("No active sessions.")


def cmd_spawn(path: str, name: str = ""):
    path = os.path.abspath(os.path.expanduser(path))
    print(f"Spawning session in {path}...")
    payload = {"cmd": "spawn", "cwd": path}
    if name:
        payload["session_name"] = name
    r = _send(payload, timeout=150)
    if not _ok(r):
        sys.exit(1)
    print(f"Session spawned:")
    print(f"  session_id:   {r.get('session_id', '?')}")
    print(f"  tmux_session: {r.get('tmux_session', '?')}")
    print(f"  daemon_id:    {r.get('daemon_id', '?')}")
    print(f"\nAttach with: vmux attach {r.get('session_id', '?')}")


def cmd_kill(session_id: str):
    r = _send({"cmd": "kill", "session_id": session_id})
    if _ok(r):
        print(f"Session {session_id} killed.")


def _resolve_session_by_cwd() -> str:
    """Find a session whose cwd matches the current working directory."""
    cwd = os.getcwd()
    r = _send({"cmd": "list"})
    if not _ok(r):
        sys.exit(1)
    sessions = r.get("sessions", [])
    if not sessions:
        _die("No active sessions. Spawn one first with: vmux spawn <path>")
    matches = [s for s in sessions if s.get("cwd", "").rstrip("/") == cwd.rstrip("/")]
    if len(matches) == 1:
        sid = matches[0].get("relay_session_id") or matches[0].get("session_id", "")
        name = matches[0].get("session_name", "")
        label = f" ({name})" if name else ""
        print(f"Auto-detected session{label} for {cwd}")
        return sid
    if len(matches) > 1:
        print(f"Multiple sessions found for {cwd}:\n")
        for s in matches:
            relay_id = s.get("relay_session_id") or "(pending)"
            name = s.get("session_name", "")
            status = s.get("status", "?")
            header = f"  [{status}] {name} ({relay_id})" if name else f"  [{status}] {relay_id}"
            print(header)
        print(f"\nSpecify one: vmux attach <session-id>")
        sys.exit(1)
    # No match — show available sessions to help the user
    print(f"No session found for {cwd}\n")
    print("Active sessions:")
    for s in sessions:
        relay_id = s.get("relay_session_id") or "(pending)"
        name = s.get("session_name", "")
        s_cwd = s.get("cwd", "")
        label = f" {name}" if name else ""
        print(f"  {relay_id}{label}  {s_cwd}")
    print(f"\nAttach by ID: vmux attach <session-id>")
    sys.exit(1)


def cmd_attach(session_id: str):
    r = _send({"cmd": "attach-info", "session_id": session_id})
    if not _ok(r):
        return
    tmux_session = r.get("tmux_session", "")
    if not tmux_session:
        _die("No tmux session info returned")
    print(f"Attaching to {tmux_session}...")
    os.execlp("tmux", "tmux", "attach-session", "-t", tmux_session)


def cmd_sessions():
    r = _send({"cmd": "list"})
    if not _ok(r):
        return
    sessions = r.get("sessions", [])
    if not sessions:
        print("No active sessions.")
        return
    print(f"Sessions ({len(sessions)}):")
    for s in sessions:
        relay_id = s.get("relay_session_id") or "(pending)"
        status = s.get("status", "?")
        cwd = s.get("cwd", "")
        tmux = s.get("tmux_session", "")
        name = s.get("session_name", "")
        header = f"  [{status}] {name} ({relay_id})" if name else f"  [{status}] {relay_id}"
        print(header)
        print(f"            cwd:  {cwd}")
        print(f"            tmux: {tmux}")


def cmd_restart(target: str):
    if target in SERVICES:
        r = _send({"cmd": "restart", "service": target})
    else:
        r = _send({"cmd": "restart-session", "session_id": target})
    if _ok(r):
        print(f"Restarted: {target}")
        if r.get("session_id"):
            print(f"New session_id: {r.get('session_id')}")


def cmd_reconnect(cwd: str):
    cwd = os.path.abspath(os.path.expanduser(cwd))
    print(f"Attempting to reconnect session in {cwd}...")
    r = _send({"cmd": "reconnect-session", "cwd": cwd})
    if _ok(r):
        print(f"Reconnect command sent. If a session with that cwd exists, it should re-enter standby shortly.")


def cmd_interrupt(session_id: str):
    r = _send({"cmd": "interrupt", "session_id": session_id})
    if _ok(r):
        print(f"Sent Ctrl-C to {session_id}.")


def cmd_hard_interrupt(session_id: str):
    print(f"Sending hard interrupt to {session_id} (Ctrl-C + MCP reconnect + standby)...")
    r = _send({"cmd": "hard-interrupt", "session_id": session_id})
    if _ok(r):
        print(f"Hard interrupt sent.")


def cmd_send(target: str, text: str):
    # If target looks like a path, compute session_id from it
    if os.path.sep in target or target.startswith("~"):
        import hashlib
        cwd = os.path.abspath(os.path.expanduser(target))
        target = hashlib.sha256(cwd.encode()).hexdigest()[:12]
    r = _send({"cmd": "send-message", "session_id": target, "text": text})
    if _ok(r):
        print(f"Message sent to {target}.")


def cmd_send_keys(session_id: str, keys: str):
    r = _send({"cmd": "send-keys", "session_id": session_id, "keys": keys})
    if _ok(r):
        print("Keys sent.")


def cmd_send_key(session_id: str, key: str):
    r = _send({"cmd": "send-keys", "session_id": session_id, "special_key": key})
    if _ok(r):
        print(f"Key '{key}' sent.")


def cmd_auth_code():
    r = _send({"cmd": "auth-code"})
    if not _ok(r):
        return
    code = r.get("code")
    expires = r.get("expires_in", 60)
    if code:
        print(f"\nPairing code: {code}  (expires in {expires}s)\n")
        print("Open the web app and enter this code to authorize a new device.")
    else:
        print("Authentication is not enabled (no AUTH_SECRET configured).")


def cmd_update():
    r = _send({"cmd": "update-if-newer"})
    if not _ok(r):
        return
    if r.get("updated"):
        print(f"Updated to version {r.get('version')}. Daemon will restart via launchd.")
    else:
        print(f"Up to date ({r.get('current', '?')}). Latest in cache: {r.get('latest', '?')}")


def cmd_shutdown():
    r = _send({"cmd": "shutdown"})
    if _ok(r):
        print("Daemon shutting down...")


def _find_project_root() -> str:
    """Find the project root containing overlay/.

    Checks VMUX_PLUGIN_DIR (set by the daemon/init system), then falls
    back to walking up from this script's location.
    """
    plugin_dir = os.environ.get("VMUX_PLUGIN_DIR", "")
    if plugin_dir and os.path.isdir(os.path.join(plugin_dir, "overlay")):
        return plugin_dir

    # Script may be the installed copy in ~/.claude/voice-multiplexer/daemon/
    # or the repo copy in <repo>/daemon/. Walk up and look for overlay/.
    # Resolve symlinks first so ~/.local/bin/vmux -> .../daemon/vmux finds the repo.
    script_path = os.path.realpath(__file__)
    script_dir = os.path.dirname(script_path)
    candidate = os.path.dirname(script_dir)
    if os.path.isdir(os.path.join(candidate, "overlay")):
        return candidate

    # Try reading VMUX_PLUGIN_DIR from the daemon state
    state_file = os.path.join(os.path.expanduser("~/.claude/voice-multiplexer"), "daemon.state")
    if os.path.exists(state_file):
        try:
            with open(state_file) as f:
                state = json.load(f)
            pd = state.get("plugin_dir", "")
            if pd and os.path.isdir(os.path.join(pd, "overlay")):
                return pd
        except Exception:
            pass

    _die(
        "Cannot find project root with overlay/ directory.\n"
        "  Set VMUX_PLUGIN_DIR to your repo path, e.g.:\n"
        "    VMUX_PLUGIN_DIR=~/claude-voice-multiplexer vmux install-overlay"
    )


def _find_uv() -> str:
    """Find the uv binary."""
    # Check common locations
    for candidate in [
        shutil.which("uv"),
        os.path.expanduser("~/.local/bin/uv"),
        os.path.expanduser("~/.cargo/bin/uv"),
    ]:
        if candidate and os.path.isfile(candidate):
            return candidate
    _die("uv not found. Install it: curl -LsSf https://astral.sh/uv/install.sh | sh")


OVERLAY_CONFIG_DIR = os.path.expanduser("~/.claude/voice-multiplexer")
OVERLAY_CONFIG_PATH = os.path.join(OVERLAY_CONFIG_DIR, "overlay.json")
OVERLAY_DAEMON_DIR = os.path.join(OVERLAY_CONFIG_DIR, "daemon")

DEFAULT_OVERLAY_CONFIG = {
    "relay_url": "http://localhost:3100",
    "position": "right",
    "screen": 0,
    "width": 420,
    "opacity": 0.96,
    "always_on_top": True,
    "shortcut_toggle_window": "<ctrl>+<shift>+v",
    "shortcut_toggle_mic": "<ctrl>+<shift>+m",
}


def cmd_install_overlay():
    """Install overlay deps, generate config, register startup, start."""
    project_root = _find_project_root()
    overlay_dir = os.path.join(project_root, "overlay")

    if not os.path.isdir(overlay_dir):
        _die(f"overlay/ directory not found at {overlay_dir}")

    uv = _find_uv()
    is_mac = sys.platform == "darwin"

    # 1. Install Python deps via uv
    print("Installing overlay dependencies...")
    venv_path = os.path.join(overlay_dir, ".venv")
    # On Linux, use the system/brew Python so PyGObject (gi) is available for pywebview GTK
    build_env = dict(os.environ)
    venv_args = [uv, "venv", "--clear"]
    if not is_mac:
        # Prefer brew's python3 (has dev headers + gi), fall back to system python3
        brew_prefix = subprocess.run(["brew", "--prefix"], capture_output=True, text=True).stdout.strip()
        brew_python = os.path.join(brew_prefix, "bin", "python3")
        if os.path.exists(brew_python):
            venv_args += ["--python", brew_python, "--system-site-packages"]
        elif os.path.exists("/usr/bin/python3"):
            venv_args += ["--python", "/usr/bin/python3", "--system-site-packages"]
        # Brew's Python may reference gcc-12 which doesn't exist — use system gcc
        if os.path.exists("/usr/bin/gcc") and not shutil.which("gcc-12"):
            build_env["CC"] = "/usr/bin/gcc"
    venv_args.append(venv_path)
    subprocess.run(venv_args, cwd=overlay_dir, check=True, env=build_env)
    # Install deps from pyproject.toml without editable install (single-file project)
    deps = [
        "pystray>=0.19", "pynput>=1.7", "pywebview>=5.0",
        "screeninfo>=0.8", "Pillow>=9.0", "cairosvg>=2.5",
    ]
    if is_mac:
        deps.append("quickmachotkey>=2025.7")
    subprocess.run(
        [uv, "pip", "install"] + deps +
        ["--python", os.path.join(venv_path, "bin", "python")],
        cwd=overlay_dir, check=True, env=build_env,
    )

    # On Linux, ensure webkit2gtk is available
    if not is_mac:
        print("Note: pywebview on Linux requires webkit2gtk (libwebkit2gtk-4.1 or similar).")
        print("      Install via your system package manager if not already present.")

    # 2. Write default overlay.json if it doesn't exist
    os.makedirs(OVERLAY_CONFIG_DIR, exist_ok=True)
    if not os.path.exists(OVERLAY_CONFIG_PATH):
        print(f"Writing default config to {OVERLAY_CONFIG_PATH}")
        with open(OVERLAY_CONFIG_PATH, "w") as f:
            json.dump(DEFAULT_OVERLAY_CONFIG, f, indent=2)
            f.write("\n")
    else:
        print(f"Config already exists at {OVERLAY_CONFIG_PATH}")

    # 3. Create vmux-overlay wrapper script
    os.makedirs(OVERLAY_DAEMON_DIR, exist_ok=True)
    wrapper_path = os.path.join(OVERLAY_DAEMON_DIR, "vmux-overlay")
    python_path = os.path.join(venv_path, "bin", "python")
    overlay_script = os.path.join(overlay_dir, "overlay.py")

    # On Linux, brew's gi can't find system GTK typelibs — set GI_TYPELIB_PATH
    gi_env_lines = ""
    if not is_mac:
        gi_typelib_dirs = []
        for d in ["/usr/lib64/girepository-1.0", "/usr/lib/girepository-1.0",
                  "/usr/lib/x86_64-linux-gnu/girepository-1.0"]:
            if os.path.isdir(d):
                gi_typelib_dirs.append(d)
        if gi_typelib_dirs:
            gi_env_lines = "\nexport GI_TYPELIB_PATH=\"" + ":".join(gi_typelib_dirs) + ":${GI_TYPELIB_PATH:-}\""

    wrapper_content = f"""#!/usr/bin/env bash
# vmux-overlay wrapper — auto-generated by vmux install-overlay{gi_env_lines}
exec "{python_path}" "{overlay_script}" "$@"
"""
    with open(wrapper_path, "w") as f:
        f.write(wrapper_content)
    os.chmod(wrapper_path, 0o755)
    print(f"Created wrapper script: {wrapper_path}")

    # 4. Register startup item
    if is_mac:
        app_bundle = os.path.join(overlay_dir, "VmuxOverlay.app")
        app_executable = os.path.join(app_bundle, "Contents", "MacOS", "vmux-overlay")
        if os.path.exists(app_executable):
            _register_launchd(app_executable)
        else:
            print(f"Warning: app bundle not found at {app_bundle}, using wrapper script")
            _register_launchd(wrapper_path)
    else:
        _register_systemd(wrapper_path)

    # 5. Start the overlay
    print("Starting vmux-overlay...")
    if is_mac:
        # Kill any existing overlay first
        subprocess.run(["pkill", "-f", "overlay.py"], capture_output=True)
        import time; time.sleep(1)
        subprocess.run(["launchctl", "load", "-w",
                        os.path.expanduser("~/Library/LaunchAgents/com.vmux.overlay.plist")])
    else:
        subprocess.run(["systemctl", "--user", "start", "vmux-overlay"])

    print("\nvmux-overlay installed and started!")
    print(f"  Config: {OVERLAY_CONFIG_PATH}")
    print(f"  Wrapper: {wrapper_path}")


def _register_launchd(executable_path: str):
    """Register a macOS launchd plist for the overlay.

    Uses 'open -a' to launch via the app bundle for proper identity.
    Falls back to direct execution if the path isn't in an app bundle.
    """
    plist_dir = os.path.expanduser("~/Library/LaunchAgents")
    os.makedirs(plist_dir, exist_ok=True)
    plist_path = os.path.join(plist_dir, "com.vmux.overlay.plist")

    log_dir = os.path.join(OVERLAY_CONFIG_DIR, "logs")
    os.makedirs(log_dir, exist_ok=True)

    # Check if the executable is inside an app bundle
    app_bundle = None
    parts = executable_path.split(os.sep)
    for i, part in enumerate(parts):
        if part.endswith(".app"):
            app_bundle = os.sep.join(parts[:i + 1])
            break

    if app_bundle:
        # Use 'open -a' to launch via the app bundle for proper identity
        program_args = f"""  <array>
    <string>/usr/bin/open</string>
    <string>-a</string>
    <string>{app_bundle}</string>
  </array>"""
    else:
        program_args = f"""  <array>
    <string>{executable_path}</string>
  </array>"""

    plist_content = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.vmux.overlay</string>
  <key>ProgramArguments</key>
{program_args}
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>{log_dir}/overlay.log</string>
  <key>StandardErrorPath</key>
  <string>{log_dir}/overlay.log</string>
</dict>
</plist>
"""
    with open(plist_path, "w") as f:
        f.write(plist_content)
    print(f"Registered launchd agent: {plist_path}")


def _register_systemd(wrapper_path: str):
    """Register a Linux systemd user service for the overlay."""
    systemd_dir = os.path.expanduser("~/.config/systemd/user")
    os.makedirs(systemd_dir, exist_ok=True)
    service_path = os.path.join(systemd_dir, "vmux-overlay.service")

    log_dir = os.path.join(OVERLAY_CONFIG_DIR, "logs")
    os.makedirs(log_dir, exist_ok=True)

    service_content = f"""[Unit]
Description=vmux-overlay — system tray overlay for Claude Voice Multiplexer
After=graphical-session.target

[Service]
Type=simple
ExecStart={wrapper_path}
Restart=on-failure
RestartSec=5
Environment=DISPLAY=:0

[Install]
WantedBy=graphical-session.target
"""
    with open(service_path, "w") as f:
        f.write(service_content)

    subprocess.run(["systemctl", "--user", "daemon-reload"])
    subprocess.run(["systemctl", "--user", "enable", "vmux-overlay"])
    print(f"Registered systemd user service: {service_path}")


def cmd_uninstall_overlay():
    """Stop overlay, remove startup item, optionally remove config."""
    is_mac = sys.platform == "darwin"

    # Stop the overlay
    print("Stopping vmux-overlay...")
    if is_mac:
        plist_path = os.path.expanduser("~/Library/LaunchAgents/com.vmux.overlay.plist")
        if os.path.exists(plist_path):
            subprocess.run(["launchctl", "unload", "-w", plist_path])
            os.remove(plist_path)
            print(f"Removed launchd agent: {plist_path}")
        else:
            print("No launchd agent found.")
    else:
        subprocess.run(["systemctl", "--user", "stop", "vmux-overlay"])
        subprocess.run(["systemctl", "--user", "disable", "vmux-overlay"])
        service_path = os.path.expanduser("~/.config/systemd/user/vmux-overlay.service")
        if os.path.exists(service_path):
            os.remove(service_path)
            subprocess.run(["systemctl", "--user", "daemon-reload"])
            print(f"Removed systemd service: {service_path}")
        else:
            print("No systemd service found.")

    # Remove wrapper script
    wrapper_path = os.path.join(OVERLAY_DAEMON_DIR, "vmux-overlay")
    if os.path.exists(wrapper_path):
        os.remove(wrapper_path)
        print(f"Removed wrapper: {wrapper_path}")

    # Ask about config removal
    if os.path.exists(OVERLAY_CONFIG_PATH):
        answer = input(f"Remove config at {OVERLAY_CONFIG_PATH}? [y/N] ").strip().lower()
        if answer in ("y", "yes"):
            os.remove(OVERLAY_CONFIG_PATH)
            print("Config removed.")
        else:
            print("Config preserved.")

    # Remove venv
    project_root = _find_project_root()
    venv_path = os.path.join(project_root, "overlay", ".venv")
    if os.path.isdir(venv_path):
        shutil.rmtree(venv_path)
        print(f"Removed overlay venv: {venv_path}")

    print("\nvmux-overlay uninstalled.")


def usage():
    print(__doc__)
    sys.exit(0)


def main():
    if len(sys.argv) < 2:
        usage()

    sub = sys.argv[1]

    if sub in ("status",):
        cmd_status()
    elif sub == "spawn":
        if len(sys.argv) < 3:
            _die("Usage: vmux spawn <path> [--name <name>]")
        spawn_args = sys.argv[2:]
        spawn_path = spawn_args[0]
        spawn_name = ""
        if "--name" in spawn_args:
            idx = spawn_args.index("--name")
            if idx + 1 < len(spawn_args):
                spawn_name = spawn_args[idx + 1]
            else:
                _die("--name requires a value")
        cmd_spawn(spawn_path, name=spawn_name)
    elif sub == "kill":
        if len(sys.argv) < 3:
            _die("Usage: vmux kill <session-id>")
        cmd_kill(sys.argv[2])
    elif sub == "attach":
        if len(sys.argv) < 3:
            session_id = _resolve_session_by_cwd()
            cmd_attach(session_id)
        else:
            cmd_attach(sys.argv[2])
    elif sub == "sessions":
        cmd_sessions()
    elif sub == "restart":
        if len(sys.argv) < 3:
            _die("Usage: vmux restart <session-id|service>")
        cmd_restart(sys.argv[2])
    elif sub == "reconnect":
        if len(sys.argv) < 3:
            _die("Usage: vmux reconnect <path>")
        cmd_reconnect(sys.argv[2])
    elif sub == "interrupt":
        if len(sys.argv) < 3:
            _die("Usage: vmux interrupt <session-id>")
        cmd_interrupt(sys.argv[2])
    elif sub == "hard-interrupt":
        if len(sys.argv) < 3:
            _die("Usage: vmux hard-interrupt <session-id>")
        cmd_hard_interrupt(sys.argv[2])
    elif sub == "send":
        if len(sys.argv) < 4:
            _die("Usage: vmux send <session-id|path> <text>\n  Use '-' for text to read from stdin")
        target = sys.argv[2]
        text = sys.argv[3]
        if text == "-":
            text = sys.stdin.read().strip()
        if not text:
            _die("No text provided")
        cmd_send(target, text)
    elif sub == "send-keys":
        if len(sys.argv) < 4:
            _die("Usage: vmux send-keys <session-id> <text>")
        cmd_send_keys(sys.argv[2], sys.argv[3])
    elif sub == "send-key":
        if len(sys.argv) < 4:
            _die("Usage: vmux send-key <session-id> <key>\n  Special keys: Enter, C-c, Escape, Tab, Up, Down, Left, Right")
        cmd_send_key(sys.argv[2], sys.argv[3])
    elif sub in ("auth-code", "authcode"):
        cmd_auth_code()
    elif sub in ("update", "update-if-newer"):
        cmd_update()
    elif sub == "install-overlay":
        cmd_install_overlay()
    elif sub == "uninstall-overlay":
        cmd_uninstall_overlay()
    elif sub == "shutdown":
        cmd_shutdown()
    elif sub in ("-h", "--help", "help"):
        usage()
    else:
        _die(f"Unknown command: {sub}\nRun 'vmux help' for usage.")


if __name__ == "__main__":
    main()
